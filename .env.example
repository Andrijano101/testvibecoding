# Srpska Transparentnost — environment configuration
# Copy to .env and adjust for your deployment

# =============================================================================
# NEO4J DATABASE
# =============================================================================
NEO4J_AUTH=neo4j/changeme123
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme123

# Memory settings (increase for large datasets)
NEO4J_HEAP_MAX=4G
NEO4J_PAGECACHE=2G

# =============================================================================
# BACKEND
# =============================================================================
# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Scraping delay between requests (seconds) — be respectful to public portals
SCRAPE_DELAY=1.5

# Request timeout for scrapers
SCRAPER_TIMEOUT=60

# =============================================================================
# DATA COLLECTION LIMITS
# =============================================================================

# UJN OpenData bulk procurement downloader
# last:N = last N years; or explicit comma list: 2024,2023,2022
PROCUREMENT_YEARS=last:3
# Max award-decision rows to load per year
PROCUREMENT_MAX_ROWS=5000

# JN Portal (jnportal.ujn.gov.rs) live contract scraper
# Number of contracts to fetch (sorted by value DESC + date DESC)
JNPORTAL_MAX_ROWS=5000
# Skip contracts below this value (RSD) — 1M default filters out micro-purchases
JNPORTAL_MIN_VALUE=1000000
JNPORTAL_PAGE_SIZE=100

# CompanyWall scraper — APR company + director data
# Number of top companies by contract value to enrich with director info
CW_MAX_COMPANIES=500

# APR Director scraper
APR_MAX_COMPANIES=200

# =============================================================================
# SCHEDULER (optional — auto-refresh data in background)
# =============================================================================
ENABLE_SCHEDULER=false
# SCRAPE_INTERVAL_HOURS=24
